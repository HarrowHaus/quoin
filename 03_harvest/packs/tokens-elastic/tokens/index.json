      "delay": "0ms",
      "timingFunction": "{ease-standard}"
    },
    "$type": "transition"
  },
  "transition-transform": {
    "$value": {
      "duration": "{motion-normal}",
      "delay": "0ms",
      "timingFunction": "{ease-standard}"
    },
    "$type": "transition"
  },
  "transition-opacity": {
    "$value": {
      "duration": "{motion-fast}",
      "delay": "0ms",
      "timingFunction": "{ease-standard}"
    },
    "$type": "transition"
  },
  "stroke-dashed": {
    "$value": {
      "dashArray": [
        "4px",
        "2px"
      ],
      "lineCap": "butt"
    },
    "$type": "strokeStyle"
  }
}
