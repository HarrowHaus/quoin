{
  "name": "geist",
  "description": "Vercel Geist design language tokens translated onto the Quoin canonical semantic-token namespace.",
  "license": "MIT",
  "tags": ["geist", "vercel", "monochrome", "developer-tools"],
  "attribution": {
    "sourceSystem": "Geist Design Language",
    "sourceOrganization": "Vercel",
    "sourceUrl": "https://vercel.com/geist",
    "sourceLicense": "MIT",
    "harvestedAt": "2026-05-16",
    "harvestNotes": "Geist is published as @vercel/geist-ui in earlier form and as the Vercel design system more recently. Highly monochrome — almost pure white surfaces and near-black text. Geist Sans / Geist Mono are open-source via Vercel under SIL OFL; referenced by family name."
  },
  "mappingNotes": "Geist's gray scale (gray-100 = near-white, gray-1000 = near-black) maps directly to Quoin's surface/text ramp. Accent is the brand near-black; status colours from Vercel's red-700 / green-700 / yellow-700 / blue-700 palette.",
  "base": {
    "gray": {
      "0":    "#ffffff",
      "100":  "oklch(98% 0.001 0)",
      "200":  "oklch(96% 0.001 0)",
      "300":  "oklch(92% 0.002 0)",
      "400":  "oklch(85% 0.002 0)",
      "500":  "oklch(70% 0.002 0)",
      "600":  "oklch(55% 0.002 0)",
      "700":  "oklch(40% 0.002 0)",
      "800":  "oklch(28% 0.002 0)",
      "900":  "oklch(18% 0.002 0)",
      "1000": "oklch(10% 0.002 0)"
    },
    "red":    { "700": "oklch(52% 0.21 25)" },
    "green":  { "700": "oklch(50% 0.16 145)" },
    "yellow": { "700": "oklch(72% 0.18 80)" },
    "blue":   { "700": "oklch(50% 0.18 240)", "100": "oklch(96% 0.04 240)" }
  },
  "fonts": {
    "font-sans": "'Geist Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif",
    "font-serif": "ui-serif, Georgia, serif",
    "font-mono": "'Geist Mono', ui-monospace, 'SF Mono', monospace",
    "font-display": "'Geist Sans', system-ui, sans-serif"
  },
  "semantic": {
    "surface": "{gray.0}",
    "surface-elevated": "{gray.0}",
    "surface-recessed": "{gray.100}",
    "surface-inverse": "{gray.1000}",
    "text": "{gray.900}",
    "text-emphasis": "{gray.1000}",
    "text-recede": "{gray.600}",
    "text-disabled": "{gray.400}",
    "text-on-accent": "{gray.0}",
    "text-on-critical": "{gray.0}",
    "text-on-success": "{gray.0}",
    "text-on-warning": "{gray.1000}",
    "text-on-info": "{gray.0}",
    "border": "{gray.300}",
    "border-emphasis": "{gray.1000}",
    "border-recede": "{gray.200}",
    "accent": "{gray.1000}",
    "accent-recede": "{gray.200}",
    "critical": "{red.700}",
    "success": "{green.700}",
    "warning": "{yellow.700}",
    "info": "{blue.700}"
  }
}
