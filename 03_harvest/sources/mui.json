{
  "name": "mui",
  "description": "Material UI (MUI) default theme translated onto the Quoin canonical semantic-token namespace.",
  "license": "MIT",
  "tags": [
    "mui",
    "material-ui",
    "react",
    "indigo-pink"
  ],
  "attribution": {
    "sourceSystem": "Material UI",
    "sourceOrganization": "MUI",
    "sourceUrl": "https://raw.githubusercontent.com/mui/material-ui/master/packages/mui-material/src/colors/indigo.js",
    "sourceLicense": "MIT",
    "harvestedAt": "2026-05-17",
    "harvestNotes": "Material UI default (Material Design v1/v2) palettes: indigo + grey + red + green + orange + blue. Each file ships a flat hex object; we capture step 500 + a few neighbours.\n\nExtraction notes: MUI's per-colour files (indigo.js, gray.js, red.js, etc.) share step keys; concatenating them in this pipeline collapses values into the last file's keys. Per-file fidelity extraction is deferred; OKLCH approximations of MUI's Material Design v2 palette stand, anchored to documented hex values from mui/material-ui.",
    "sourceCommit": "master",
    "fidelityTier": "B"
  },
  "mappingNotes": "MUI palette.background.default/paper -> surface/surface-elevated. palette.text.primary/secondary -> text/text-recede. palette.primary.main -> accent. palette.error/warning/info/success.main map directly.",
  "base": {
    "gray": {
      "50": "oklch(98.5% 0.001 0)",
      "100": "oklch(96% 0.002 0)",
      "200": "oklch(93% 0.003 0)",
      "400": "oklch(74% 0.005 0)",
      "700": "oklch(38% 0.008 0)",
      "900": "oklch(13% 0.01 0)"
    },
    "indigo": {
      "50": "oklch(95% 0.04 280)",
      "500": "oklch(48% 0.18 280)",
      "700": "oklch(38% 0.18 280)"
    },
    "red": {
      "500": "oklch(60% 0.22 25)"
    },
    "green": {
      "500": "oklch(58% 0.16 145)"
    },
    "amber": {
      "500": "oklch(78% 0.17 80)"
    },
    "blue": {
      "500": "oklch(58% 0.17 240)"
    },
    "white": {
      "0": "oklch(100% 0 0)"
    }
  },
  "fonts": {
    "font-sans": "Roboto, 'Helvetica Neue', Arial, sans-serif",
    "font-serif": "ui-serif, Georgia, serif",
    "font-mono": "'Roboto Mono', ui-monospace, monospace",
    "font-display": "Roboto, 'Helvetica Neue', sans-serif"
  },
  "semantic": {
    "surface": "{gray.50}",
    "surface-elevated": "{white.0}",
    "surface-recessed": "{gray.100}",
    "surface-inverse": "{gray.900}",
    "text": "{gray.900}",
    "text-emphasis": "{gray.900}",
    "text-recede": "{gray.700}",
    "text-disabled": "{gray.400}",
    "text-on-accent": "{white.0}",
    "text-on-critical": "{white.0}",
    "text-on-success": "{white.0}",
    "text-on-warning": "{gray.900}",
    "text-on-info": "{white.0}",
    "border": "{gray.200}",
    "border-emphasis": "{indigo.500}",
    "border-recede": "{gray.100}",
    "accent": "{indigo.500}",
    "accent-recede": "{indigo.50}",
    "critical": "{red.500}",
    "success": "{green.500}",
    "warning": "{amber.500}",
    "info": "{blue.500}"
  }
}
