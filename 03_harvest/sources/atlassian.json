{
  "name": "atlassian",
  "description": "Atlassian Design System (light theme) palette translated onto the Quoin canonical semantic-token namespace.",
  "license": "Apache-2.0",
  "tags": ["atlassian", "jira", "confluence", "blue-accent"],
  "attribution": {
    "sourceSystem": "Atlassian Design System",
    "sourceOrganization": "Atlassian",
    "sourceUrl": "https://atlassian.design/",
    "sourceLicense": "Apache-2.0",
    "harvestedAt": "2026-05-16",
    "harvestNotes": "Atlassian's design tokens 'light' theme. Atlassian publishes JSON token files under @atlaskit/tokens; this pack translates the color.background/text/border/accent families onto Quoin's canonical namespace. Charlie Sans (Atlassian's typeface) is proprietary; referenced by family name only."
  },
  "mappingNotes": "Atlassian's color.background.neutral.subtle -> surface, color.background.neutral -> surface-recessed, color.background.accent.blue.bold -> accent. text.color -> text, text.color.subtle -> text-recede. critical/success/warning/info from Atlassian's status- families.",
  "base": {
    "neutral": {
      "0":   "#ffffff",
      "10":  "oklch(98% 0.005 250)",
      "20":  "oklch(96% 0.008 250)",
      "30":  "oklch(92% 0.010 250)",
      "40":  "oklch(85% 0.012 250)",
      "100": "oklch(58% 0.012 250)",
      "300": "oklch(38% 0.014 250)",
      "800": "oklch(20% 0.014 250)",
      "1000": "oklch(12% 0.014 250)"
    },
    "blue": {
      "500": "oklch(50% 0.18 245)",
      "50": "oklch(96% 0.04 245)"
    },
    "red":    { "500": "oklch(52% 0.20 25)" },
    "green":  { "500": "oklch(50% 0.16 145)" },
    "yellow": { "500": "oklch(75% 0.18 80)" },
    "teal":   { "500": "oklch(55% 0.13 200)" }
  },
  "fonts": {
    "font-sans": "'Charlie Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif",
    "font-serif": "'Charlie Display', Georgia, serif",
    "font-mono": "'Charlie Mono', ui-monospace, monospace",
    "font-display": "'Charlie Display', system-ui, sans-serif"
  },
  "semantic": {
    "surface": "{neutral.0}",
    "surface-elevated": "{neutral.0}",
    "surface-recessed": "{neutral.10}",
    "surface-inverse": "{neutral.1000}",
    "text": "{neutral.1000}",
    "text-emphasis": "{neutral.1000}",
    "text-recede": "{neutral.100}",
    "text-disabled": "{neutral.40}",
    "text-on-accent": "{neutral.0}",
    "text-on-critical": "{neutral.0}",
    "text-on-success": "{neutral.0}",
    "text-on-warning": "{neutral.1000}",
    "text-on-info": "{neutral.0}",
    "border": "{neutral.30}",
    "border-emphasis": "{blue.500}",
    "border-recede": "{neutral.20}",
    "accent": "{blue.500}",
    "accent-recede": "{blue.50}",
    "critical": "{red.500}",
    "success": "{green.500}",
    "warning": "{yellow.500}",
    "info": "{teal.500}"
  }
}
