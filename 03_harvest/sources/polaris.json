{
  "name": "polaris",
  "description": "Shopify Polaris (light theme) palette translated onto the Quoin canonical semantic-token namespace.",
  "license": "MIT",
  "tags": ["polaris", "shopify", "indigo-accent", "commerce"],
  "attribution": {
    "sourceSystem": "Polaris",
    "sourceOrganization": "Shopify",
    "sourceUrl": "https://polaris.shopify.com/",
    "sourceLicense": "MIT",
    "harvestedAt": "2026-05-16",
    "harvestNotes": "Polaris v12 'light' colour tokens. Polaris ships extensive token families (--p-color-bg-*, --p-color-text-*, --p-color-border-*, etc.); this pack distills them onto Quoin's 4-surface model. Polaris's brand indigo (#2C6ECB area) sets accent."
  },
  "mappingNotes": "Polaris --p-color-bg / bg-surface -> surface, bg-surface-secondary -> surface-recessed, bg-emphasis -> accent. text -> text, text-secondary -> text-recede, text-emphasis -> text-emphasis. critical/success/warning/info map directly from Polaris's status families.",
  "base": {
    "neutral": {
      "0":  "#ffffff",
      "50": "oklch(98% 0.005 250)",
      "100": "oklch(95% 0.008 250)",
      "200": "oklch(88% 0.010 250)",
      "300": "oklch(75% 0.010 250)",
      "500": "oklch(50% 0.012 250)",
      "700": "oklch(32% 0.012 250)",
      "900": "oklch(15% 0.012 250)"
    },
    "indigo": {
      "500": "oklch(45% 0.20 260)",
      "50": "oklch(96% 0.04 260)"
    },
    "critical": { "500": "oklch(50% 0.20 25)" },
    "success":  { "500": "oklch(50% 0.16 150)" },
    "warning":  { "500": "oklch(75% 0.18 80)" },
    "info":     { "500": "oklch(55% 0.16 240)" }
  },
  "fonts": {
    "font-sans": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif",
    "font-serif": "ui-serif, Georgia, serif",
    "font-mono": "ui-monospace, 'SF Mono', Menlo, monospace",
    "font-display": "'Inter', system-ui, sans-serif"
  },
  "semantic": {
    "surface": "{neutral.0}",
    "surface-elevated": "{neutral.0}",
    "surface-recessed": "{neutral.50}",
    "surface-inverse": "{neutral.900}",
    "text": "{neutral.900}",
    "text-emphasis": "{neutral.900}",
    "text-recede": "{neutral.500}",
    "text-disabled": "{neutral.300}",
    "text-on-accent": "{neutral.0}",
    "text-on-critical": "{neutral.0}",
    "text-on-success": "{neutral.0}",
    "text-on-warning": "{neutral.900}",
    "text-on-info": "{neutral.0}",
    "border": "{neutral.200}",
    "border-emphasis": "{indigo.500}",
    "border-recede": "{neutral.100}",
    "accent": "{indigo.500}",
    "accent-recede": "{indigo.50}",
    "critical": "{critical.500}",
    "success": "{success.500}",
    "warning": "{warning.500}",
    "info": "{info.500}"
  }
}
