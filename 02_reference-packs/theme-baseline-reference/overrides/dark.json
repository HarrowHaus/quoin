{
  "$schema": "https://designtokens.org/schema-2025-10/",
  "$description": "Dark-mode overrides — inverts the greyscale and re-tunes surfaces against the canonical baseline. Names are all from the v1.0 canonical namespace; no new tokens introduced.",
  "surface":          { "$type": "color", "$value": "oklch(15% 0.005 250)" },
  "surface-elevated": { "$type": "color", "$value": "oklch(20% 0.006 250)" },
  "surface-recessed": { "$type": "color", "$value": "oklch(10% 0.004 250)" },
  "surface-inverse":  { "$type": "color", "$value": "oklch(96% 0.003 250)" },
  "scrim":            { "$type": "color", "$value": "oklch(0% 0 0 / 0.7)" },
  "text":             { "$type": "color", "$value": "oklch(92% 0.005 250)" },
  "text-emphasis":    { "$type": "color", "$value": "oklch(98% 0.003 250)" },
  "text-recede":      { "$type": "color", "$value": "oklch(68% 0.008 250)" },
  "text-disabled":    { "$type": "color", "$value": "oklch(48% 0.005 250)" },
  "highlight":        { "$type": "color", "$value": "oklch(80% 0.18 95 / 0.35)" },
  "border":           { "$type": "color", "$value": "oklch(28% 0.006 250)" },
  "border-emphasis":  { "$type": "color", "$value": "oklch(40% 0.008 250)" },
  "border-recede":    { "$type": "color", "$value": "oklch(22% 0.004 250)" },
  "accent":           { "$type": "color", "$value": "oklch(72% 0.18 250)" },
  "accent-recede":    { "$type": "color", "$value": "oklch(38% 0.10 250)" },
  "focus-ring":       { "$type": "color", "$value": "oklch(75% 0.20 250)" },
  "shadow-tint":      { "$type": "color", "$value": "oklch(0% 0 0 / 0.55)" },
  "link":             { "$type": "color", "$value": "oklch(78% 0.16 250)" },
  "link-visited":     { "$type": "color", "$value": "oklch(72% 0.15 295)" },
  "link-hover":       { "$type": "color", "$value": "oklch(85% 0.18 250)" }
}
