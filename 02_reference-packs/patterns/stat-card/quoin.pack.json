{
  "$schema": "https://harrow.haus/quoin/schema/pack.json",
  "name": "@quoin/pattern-stat-card",
  "version": "1.0.0",
  "type": "pattern",
  "quoinVersion": "^0.1.0",
  "description": "KPI tile for dashboards. Label + big numeric value + delta indicator + optional sparkline + context caption. 3 variants × 3 sizes × 4 states. Pairs with data-table.",
  "category": "product",
  "variant": "system",
  "exports": {
    "primitives": "./primitives/index.json"
  },
  "states": ["default", "loading", "error", "no-data"],
  "microStates": ["default", "hover", "active", "focus", "focus-visible", "disabled", "loading", "selected"],
  "metadata": {
    "author": "Quoin",
    "license": "MIT",
    "homepage": "https://harrow.haus/quoin/patterns/stat-card",
    "tags": ["stat-card", "kpi", "dashboard", "metric", "p0"]
  },
  "peerPacks": {
    "@quoin/tokens-baseline": "^0.1.0",
    "@quoin/pattern-button-system": "^1.0.0"
  }
}
