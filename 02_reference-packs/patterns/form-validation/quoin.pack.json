{
  "$schema": "https://harrow.haus/quoin/schema/pack.json",
  "name": "@quoin/pattern-form-validation",
  "version": "1.0.0",
  "type": "pattern",
  "quoinVersion": "^0.1.0",
  "description": "Error-summary + field-level validation messages + status icons. WCAG 2.4.6 / 3.3.1 / 3.3.3 patterns. 7 form-level states + 4 validate-on policies. Composes form-fields + button-system.",
  "category": "product",
  "variant": "system",
  "exports": {
    "primitives": "./primitives/index.json"
  },
  "states": ["default", "touched", "validating", "valid", "invalid", "submitted", "submit-failed"],
  "microStates": ["default", "hover", "active", "focus", "focus-visible", "disabled", "loading", "validating"],
  "metadata": {
    "author": "Quoin",
    "license": "MIT",
    "homepage": "https://harrow.haus/quoin/patterns/form-validation",
    "tags": ["form", "validation", "wcag", "error-summary", "p0"]
  },
  "peerPacks": {
    "@quoin/tokens-baseline": "^0.1.0",
    "@quoin/pattern-button-system": "^1.0.0",
    "@quoin/pattern-form-fields": "^1.0.0"
  }
}
