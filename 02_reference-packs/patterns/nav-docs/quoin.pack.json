{
  "$schema": "https://harrow.haus/quoin/schema/pack.json",
  "name": "@quoin/pattern-nav-docs",
  "version": "1.0.0",
  "type": "pattern",
  "quoinVersion": "^0.1.0",
  "description": "Docs site nav — top-bar with logo + search + version + theme switcher PLUS collapsible left sidebar tree. Mobile drawer. Skip-to-content. Composes button-system.",
  "category": "marketing",
  "variant": "system",
  "exports": {
    "primitives": "./primitives/index.json"
