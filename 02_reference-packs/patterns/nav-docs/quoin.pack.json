  "metadata": {
    "author": "Quoin",
    "license": "MIT",
    "homepage": "https://harrow.haus/quoin/patterns/nav-docs",
    "tags": ["nav", "docs", "sidebar", "documentation", "p1"]
  },
  "peerPacks": {
    "@quoin/tokens-baseline": "^0.1.0",
    "@quoin/pattern-button-system": "^1.0.0"
