{
  "$schema": "https://harrow.haus/quoin/schema/pack.json",
  "name": "@quoin/pattern-hero-video",
  "version": "1.0.0",
  "type": "pattern",
  "quoinVersion": "^0.1.0",
  "description": "Background-video hero — auto-playing muted loop behind canonical anatomy. WCAG 2.2.2 pause control required. Poster fallback. Hero category 5 of 5. Composes button-system.",
