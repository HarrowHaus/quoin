    "author": "Quoin",
    "license": "MIT",
    "homepage": "https://harrow.haus/quoin/patterns/modal-dialog",
    "tags": ["dialog", "modal", "command-palette", "confirmation", "p0"]
  },
  "peerPacks": {
    "@quoin/tokens-baseline": "^0.1.0",
    "@quoin/pattern-button-system": "^1.0.0",
    "@quoin/pattern-form-fields": "^1.0.0"
  }
