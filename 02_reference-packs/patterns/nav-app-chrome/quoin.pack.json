{
  "$schema": "https://harrow.haus/quoin/schema/pack.json",
  "name": "@quoin/pattern-nav-app-chrome",
  "version": "1.0.0",
  "type": "pattern",
  "quoinVersion": "^0.1.0",
  "description": "In-app top nav (Linear / Notion / Figma style) — workspace switcher + breadcrumb + Cmd+K search + notification bell + user menu + optional page tabs. Composes button-system.",
  "category": "product",
  "variant": "system",
  "exports": {
    "primitives": "./primitives/index.json"
  },
  "states": ["default", "search-open", "menu-open", "notifications-open", "offline"],
  "microStates": ["default", "hover", "active", "focus", "focus-visible", "disabled", "loading", "current"],
  "metadata": {
    "author": "Quoin",
    "license": "MIT",
    "homepage": "https://harrow.haus/quoin/patterns/nav-app-chrome",
    "tags": ["nav", "app-shell", "header", "product", "command-k", "p0"]
  },
  "peerPacks": {
    "@quoin/tokens-baseline": "^0.1.0",
    "@quoin/pattern-button-system": "^1.0.0"
  }
}
