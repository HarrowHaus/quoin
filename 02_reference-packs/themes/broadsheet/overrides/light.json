{
  "$schema": "https://designtokens.org/schema-2025-10/",
  "$description": "@quoin/theme-broadsheet — light mode. Monochrome page (true-white #fff ground, near-black ink), display-tier type sizes pushed up (5xl 96px+, display 128px). Junicode 2 at the display tier. Type does the visual work.",

  "surface":          { "$type": "color", "$value": "oklch(100% 0 0)" },
  "surface-elevated": { "$type": "color", "$value": "oklch(99% 0 0)" },
  "surface-recessed": { "$type": "color", "$value": "oklch(96% 0 0)" },
  "surface-inverse":  { "$type": "color", "$value": "oklch(10% 0 0)" },
  "scrim":            { "$type": "color", "$value": "oklch(10% 0 0 / 0.45)" },

  "text":             { "$type": "color", "$value": "oklch(14% 0 0)" },
  "text-emphasis":    { "$type": "color", "$value": "oklch(0% 0 0)" },
  "text-recede":      { "$type": "color", "$value": "oklch(40% 0 0)" },
  "text-disabled":    { "$type": "color", "$value": "oklch(70% 0 0)" },
  "text-on-accent":   { "$type": "color", "$value": "oklch(100% 0 0)" },
  "highlight":        { "$type": "color", "$value": "oklch(90% 0.12 90 / 0.35)" },

  "border":           { "$type": "color", "$value": "oklch(0% 0 0)" },
  "border-emphasis":  { "$type": "color", "$value": "oklch(0% 0 0)" },
  "border-recede":    { "$type": "color", "$value": "oklch(85% 0 0)" },

  "accent":           { "$type": "color", "$value": "oklch(0% 0 0)" },
  "accent-recede":    { "$type": "color", "$value": "oklch(35% 0 0)" },
  "focus-ring":       { "$type": "color", "$value": "oklch(50% 0.18 270)" },
  "shadow-tint":      { "$type": "color", "$value": "oklch(0% 0 0 / 0.05)" },

  "link":             { "$type": "color", "$value": "oklch(0% 0 0)" },
  "link-visited":     { "$type": "color", "$value": "oklch(30% 0 0)" },
  "link-hover":       { "$type": "color", "$value": "oklch(50% 0.18 270)" },

  "font-display": { "$type": "fontFamily", "$value": "'Junicode 2', 'Junicode', ui-serif, Georgia, serif" },
  "font-serif":   { "$type": "fontFamily", "$value": "'Junicode 2', 'Junicode', ui-serif, Georgia, serif" },
  "font-sans":    { "$type": "fontFamily", "$value": "'Ranade Variable', 'Ranade', 'Inter Variable', 'Inter', system-ui, sans-serif" },
  "font-mono":    { "$type": "fontFamily", "$value": "'JetBrains Mono Variable', 'JetBrains Mono', ui-monospace, monospace" },

  "type-size-2xl":     { "$type": "dimension", "$value": "3.5rem" },
  "type-size-3xl":     { "$type": "dimension", "$value": "5rem" },
  "type-size-4xl":     { "$type": "dimension", "$value": "7rem" },
  "type-size-5xl":     { "$type": "dimension", "$value": "9rem" },
  "type-size-display": { "$type": "dimension", "$value": "11rem" },

  "tracking-tight":  { "$type": "dimension", "$value": "-0.04em" },
  "tracking-normal": { "$type": "dimension", "$value": "-0.01em" },

  "leading-tight":  { "$type": "number", "$value": 0.95 },
  "leading-prose":  { "$type": "number", "$value": 1.55 },

  "container-narrow":  { "$type": "dimension", "$value": "640px" },
  "container-default": { "$type": "dimension", "$value": "720px" },

  "radius-md":   { "$type": "dimension", "$value": "0px" },
  "radius-lg":   { "$type": "dimension", "$value": "0px" },
  "radius-card": { "$type": "dimension", "$value": "0px" },

  "motion-fast":   { "$type": "duration", "$value": "180ms" },
  "motion-normal": { "$type": "duration", "$value": "320ms" },
  "motion-slow":   { "$type": "duration", "$value": "600ms" },

  "shadow-md": { "$type": "shadow", "$value": [
    { "color": "{shadow-tint}", "offsetX": "0", "offsetY": "0", "blur": "0", "spread": "0", "inset": false }
  ] },
  "shadow-lg": { "$type": "shadow", "$value": [
    { "color": "{shadow-tint}", "offsetX": "0", "offsetY": "0", "blur": "0", "spread": "0", "inset": false }
  ] }
}
