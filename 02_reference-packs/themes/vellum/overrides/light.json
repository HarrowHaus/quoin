{
  "$schema": "https://designtokens.org/schema-2025-10/",
  "$description": "@quoin/theme-vellum — light mode. Warm parchment palette derived from anthropic.com: page #faf9f5 (Ivory Light), ink #141413 near-black, terracotta #d97757 accent held in reserve, warm card surfaces #f0eee6 and #e3dacc. OKLCH values converted from source hex with sRGB-clamp safe.",

  "surface":          { "$type": "color", "$value": "oklch(97.5% 0.011 85)" },
  "surface-elevated": { "$type": "color", "$value": "oklch(96% 0.012 80)" },
  "surface-recessed": { "$type": "color", "$value": "oklch(92% 0.018 80)" },
  "surface-inverse":  { "$type": "color", "$value": "oklch(20% 0.005 80)" },
  "scrim":            { "$type": "color", "$value": "oklch(20% 0.005 80 / 0.5)" },

  "text":             { "$type": "color", "$value": "oklch(20% 0.006 75)" },
  "text-emphasis":    { "$type": "color", "$value": "oklch(12% 0.005 75)" },
  "text-recede":      { "$type": "color", "$value": "oklch(45% 0.008 75)" },
  "text-disabled":    { "$type": "color", "$value": "oklch(70% 0.010 80)" },
  "text-on-accent":   { "$type": "color", "$value": "oklch(98% 0.008 80)" },
  "highlight":        { "$type": "color", "$value": "oklch(72% 0.16 45 / 0.18)" },

  "border":           { "$type": "color", "$value": "oklch(86% 0.015 80)" },
  "border-emphasis":  { "$type": "color", "$value": "oklch(20% 0.006 75)" },
  "border-recede":    { "$type": "color", "$value": "oklch(91% 0.012 80)" },

  "accent":           { "$type": "color", "$value": "oklch(66% 0.14 40)" },
  "accent-recede":    { "$type": "color", "$value": "oklch(82% 0.06 40)" },
  "focus-ring":       { "$type": "color", "$value": "oklch(66% 0.14 40)" },
  "shadow-tint":      { "$type": "color", "$value": "oklch(20% 0.006 75 / 0.06)" },

  "link":             { "$type": "color", "$value": "oklch(20% 0.006 75)" },
  "link-visited":     { "$type": "color", "$value": "oklch(35% 0.010 75)" },
  "link-hover":       { "$type": "color", "$value": "oklch(66% 0.14 40)" },

  "font-display": { "$type": "fontFamily", "$value": "'Source Serif 4 Display', 'Source Serif 4', ui-serif, Georgia, 'Times New Roman', serif" },
  "font-serif":   { "$type": "fontFamily", "$value": "'Source Serif 4', ui-serif, Georgia, serif" },
  "font-sans":    { "$type": "fontFamily", "$value": "'Inter Variable', 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif" },
  "font-mono":    { "$type": "fontFamily", "$value": "'JetBrains Mono Variable', 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace" },

  "radius-md":   { "$type": "dimension", "$value": "6px" },
  "radius-lg":   { "$type": "dimension", "$value": "8px" },
  "radius-card": { "$type": "dimension", "$value": "8px" },

  "motion-fast":   { "$type": "duration", "$value": "200ms" },
  "motion-normal": { "$type": "duration", "$value": "240ms" },
  "motion-slow":   { "$type": "duration", "$value": "280ms" },

  "shadow-md": { "$type": "shadow", "$value": [
    { "color": "{shadow-tint}", "offsetX": "0", "offsetY": "1px", "blur": "2px", "spread": "0",   "inset": false }
  ] },
  "shadow-lg": { "$type": "shadow", "$value": [
    { "color": "{shadow-tint}", "offsetX": "0", "offsetY": "2px", "blur": "6px", "spread": "0",   "inset": false }
  ] }
}
