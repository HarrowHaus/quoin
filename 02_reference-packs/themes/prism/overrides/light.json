{
  "$schema": "https://designtokens.org/schema-2025-10/",
  "$description": "@quoin/theme-prism — light mode. Translucent overlays: surface-elevated and surface-recessed carry alpha values so backdrop-filter blur can reveal underlying content. SF Pro fallback on Apple platforms. Requires backdrop-filter support; impl pack documents graceful fallback to opaque elevation.",

  "surface":          { "$type": "color", "$value": "oklch(98% 0.005 240)" },
  "surface-elevated": { "$type": "color", "$value": "oklch(98% 0.005 240 / 0.45)" },
  "surface-recessed": { "$type": "color", "$value": "oklch(94% 0.008 240 / 0.55)" },
  "surface-inverse":  { "$type": "color", "$value": "oklch(15% 0.015 240)" },
  "scrim":            { "$type": "color", "$value": "oklch(15% 0.015 240 / 0.35)" },

  "text":             { "$type": "color", "$value": "oklch(18% 0.012 240)" },
  "text-emphasis":    { "$type": "color", "$value": "oklch(8% 0.010 240)" },
  "text-recede":      { "$type": "color", "$value": "oklch(48% 0.012 240)" },
  "text-disabled":    { "$type": "color", "$value": "oklch(72% 0.008 240)" },
  "text-on-accent":   { "$type": "color", "$value": "oklch(98% 0.005 240)" },
  "highlight":        { "$type": "color", "$value": "oklch(70% 0.18 230 / 0.30)" },

  "border":           { "$type": "color", "$value": "oklch(85% 0.012 240 / 0.6)" },
  "border-emphasis":  { "$type": "color", "$value": "oklch(60% 0.18 230)" },
  "border-recede":    { "$type": "color", "$value": "oklch(92% 0.008 240 / 0.5)" },

  "accent":           { "$type": "color", "$value": "oklch(60% 0.18 230)" },
  "accent-recede":    { "$type": "color", "$value": "oklch(78% 0.12 230)" },
  "focus-ring":       { "$type": "color", "$value": "oklch(60% 0.18 230)" },
  "shadow-tint":      { "$type": "color", "$value": "oklch(15% 0.015 240 / 0.10)" },

  "link":             { "$type": "color", "$value": "oklch(60% 0.18 230)" },
  "link-visited":     { "$type": "color", "$value": "oklch(55% 0.14 295)" },
  "link-hover":       { "$type": "color", "$value": "oklch(50% 0.20 230)" },

  "font-display": { "$type": "fontFamily", "$value": "'SF Pro Display', '-apple-system', 'Inter Display Variable', 'Inter Display', system-ui, sans-serif" },
  "font-sans":    { "$type": "fontFamily", "$value": "'SF Pro Text', '-apple-system', 'Inter Variable', 'Inter', system-ui, sans-serif" },
  "font-mono":    { "$type": "fontFamily", "$value": "'SF Mono', 'JetBrains Mono Variable', 'JetBrains Mono', ui-monospace, Menlo, monospace" },

  "blur-sm": { "$type": "dimension", "$value": "12px" },
  "blur-md": { "$type": "dimension", "$value": "20px" },
  "blur-lg": { "$type": "dimension", "$value": "32px" },

  "radius-md":   { "$type": "dimension", "$value": "12px" },
  "radius-lg":   { "$type": "dimension", "$value": "20px" },
  "radius-card": { "$type": "dimension", "$value": "28px" },
  "radius-pill": { "$type": "dimension", "$value": "999px" },

  "motion-fast":   { "$type": "duration", "$value": "200ms" },
  "motion-normal": { "$type": "duration", "$value": "320ms" },
  "motion-slow":   { "$type": "duration", "$value": "400ms" },

  "shadow-md": { "$type": "shadow", "$value": [
    { "color": "{shadow-tint}", "offsetX": "0", "offsetY": "1px",  "blur": "2px",  "spread": "0", "inset": false },
    { "color": "{shadow-tint}", "offsetX": "0", "offsetY": "6px",  "blur": "20px", "spread": "-6px", "inset": false }
  ] },
  "shadow-lg": { "$type": "shadow", "$value": [
    { "color": "{shadow-tint}", "offsetX": "0", "offsetY": "12px", "blur": "32px", "spread": "-10px", "inset": false }
  ] }
}
