{
  "$schema": "https://designtokens.org/schema-2025-10/",
  "$description": "@quoin/theme-bloom — dark mode. Plum-and-rose dusk register: deep mauve grounds, warm-rose ink, peach accent preserved. The gradient mesh becomes more saturated against the darker surface.",

  "surface":          { "$type": "color", "$value": "oklch(18% 0.025 320)" },
  "surface-elevated": { "$type": "color", "$value": "oklch(22% 0.030 330)" },
  "surface-recessed": { "$type": "color", "$value": "oklch(12% 0.020 320)" },
  "surface-inverse":  { "$type": "color", "$value": "oklch(95% 0.020 40)" },
  "scrim":            { "$type": "color", "$value": "oklch(8% 0.015 320 / 0.72)" },

  "text":             { "$type": "color", "$value": "oklch(90% 0.020 40)" },
  "text-emphasis":    { "$type": "color", "$value": "oklch(98% 0.018 40)" },
  "text-recede":      { "$type": "color", "$value": "oklch(65% 0.025 40)" },
  "text-disabled":    { "$type": "color", "$value": "oklch(42% 0.022 40)" },
  "text-on-accent":   { "$type": "color", "$value": "oklch(15% 0.020 320)" },
  "highlight":        { "$type": "color", "$value": "oklch(75% 0.18 25 / 0.32)" },

  "border":           { "$type": "color", "$value": "oklch(30% 0.030 330)" },
  "border-emphasis":  { "$type": "color", "$value": "oklch(75% 0.18 25)" },
  "border-recede":    { "$type": "color", "$value": "oklch(22% 0.025 330)" },

  "accent":           { "$type": "color", "$value": "oklch(78% 0.18 25)" },
  "accent-recede":    { "$type": "color", "$value": "oklch(50% 0.14 25)" },
  "focus-ring":       { "$type": "color", "$value": "oklch(78% 0.18 25)" },
  "shadow-tint":      { "$type": "color", "$value": "oklch(0% 0 0 / 0.50)" },

  "link":             { "$type": "color", "$value": "oklch(82% 0.16 25)" },
  "link-visited":     { "$type": "color", "$value": "oklch(72% 0.14 320)" },
  "link-hover":       { "$type": "color", "$value": "oklch(90% 0.18 25)" }
}
