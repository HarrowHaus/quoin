{
  "$schema": "https://designtokens.org/schema-2025-10/",
  "$description": "@quoin/theme-terminal — dark mode (canonical). True-black ground, terminal-cream ink, acid-lime accent oklch(85% 0.20 130). The default surface; light mode is the bidirectional courtesy.",

  "surface":          { "$type": "color", "$value": "oklch(0% 0 0)" },
  "surface-elevated": { "$type": "color", "$value": "oklch(6% 0 0)" },
  "surface-recessed": { "$type": "color", "$value": "oklch(0% 0 0)" },
  "surface-inverse":  { "$type": "color", "$value": "oklch(98% 0.005 100)" },
  "scrim":            { "$type": "color", "$value": "oklch(0% 0 0 / 0.85)" },

  "text":             { "$type": "color", "$value": "oklch(90% 0.012 100)" },
  "text-emphasis":    { "$type": "color", "$value": "oklch(98% 0.008 100)" },
  "text-recede":      { "$type": "color", "$value": "oklch(60% 0.008 100)" },
  "text-disabled":    { "$type": "color", "$value": "oklch(35% 0.005 100)" },
  "text-on-accent":   { "$type": "color", "$value": "oklch(0% 0 0)" },
  "highlight":        { "$type": "color", "$value": "oklch(85% 0.20 130 / 0.35)" },

  "border":           { "$type": "color", "$value": "oklch(35% 0.008 100)" },
  "border-emphasis":  { "$type": "color", "$value": "oklch(85% 0.20 130)" },
  "border-recede":    { "$type": "color", "$value": "oklch(18% 0.005 100)" },

  "accent":           { "$type": "color", "$value": "oklch(85% 0.22 130)" },
  "accent-recede":    { "$type": "color", "$value": "oklch(58% 0.18 130)" },
  "focus-ring":       { "$type": "color", "$value": "oklch(85% 0.22 130)" },
  "shadow-tint":      { "$type": "color", "$value": "oklch(0% 0 0 / 0)" },

  "link":             { "$type": "color", "$value": "oklch(85% 0.22 130)" },
  "link-visited":     { "$type": "color", "$value": "oklch(72% 0.16 130)" },
  "link-hover":       { "$type": "color", "$value": "oklch(95% 0.22 130)" }
}
