  "_comment_3_27_transition": "§3.27 transition (composite, 6 — handoff additive)",
  "transition-default": {
    "$type": "transition",
    "$value": { "duration": "{motion-normal}", "delay": "0ms", "timingFunction": "{ease-standard}" }
  },
  "transition-emphasis": {
    "$type": "transition",
    "$value": { "duration": "{motion-slow}", "delay": "0ms", "timingFunction": "{ease-emphasized}" }
  },
  "transition-fast": {
    "$type": "transition",
