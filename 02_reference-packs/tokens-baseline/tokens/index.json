{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Quoin baseline token pack. Neutral stone-greyscale palette in OKLCH, system font stack, restrained spacing/type/motion scale. Implements every name in the canonical semantic-token namespace from 00_spec/tokens.md §2.",

  "color": {
    "stone": {
      "50":  { "$value": "oklch(98% 0 0)",     "$type": "color" },
      "100": { "$value": "oklch(96% 0 0)",     "$type": "color" },
      "200": { "$value": "oklch(90% 0 0)",     "$type": "color" },
      "300": { "$value": "oklch(80% 0 0)",     "$type": "color" },
      "400": { "$value": "oklch(65% 0 0)",     "$type": "color" },
      "500": { "$value": "oklch(50% 0 0)",     "$type": "color" },
      "600": { "$value": "oklch(40% 0 0)",     "$type": "color" },
      "700": { "$value": "oklch(30% 0 0)",     "$type": "color" },
      "800": { "$value": "oklch(20% 0 0)",     "$type": "color" },
      "900": { "$value": "oklch(15% 0 0)",     "$type": "color" }
    },
    "white":   { "$value": "#ffffff",              "$type": "color" },
    "red":     { "$value": "oklch(55% 0.22 25)",   "$type": "color" },
    "red-soft":{ "$value": "oklch(95% 0.04 25)",   "$type": "color" },
    "amber":   { "$value": "oklch(75% 0.18 80)",   "$type": "color" },
    "amber-soft": { "$value": "oklch(96% 0.05 80)","$type": "color" },
    "emerald": { "$value": "oklch(58% 0.18 155)",  "$type": "color" },
    "emerald-soft": { "$value": "oklch(95% 0.05 155)", "$type": "color" },
    "sky":     { "$value": "oklch(70% 0.15 235)",  "$type": "color" },
    "sky-soft":{ "$value": "oklch(95% 0.04 235)",  "$type": "color" }
  },

  "surface":          { "$value": "{color.stone.50}",  "$type": "color", "$description": "Default page or container background." },
  "surface-elevated": { "$value": "{color.white}",     "$type": "color", "$description": "Raised surfaces: cards, panels, modals." },
  "surface-recessed": { "$value": "{color.stone.100}", "$type": "color", "$description": "Sunken surfaces: insets, code blocks, aside backgrounds." },
  "surface-inverse":  { "$value": "{color.stone.900}", "$type": "color" },

  "text":             { "$value": "{color.stone.700}", "$type": "color", "$description": "Default body text." },
  "text-emphasis":    { "$value": "{color.stone.900}", "$type": "color", "$description": "Headlines, primary emphasis." },
  "text-recede":      { "$value": "{color.stone.500}", "$type": "color", "$description": "De-emphasized text: metadata, captions, secondary info." },
  "text-disabled":    { "$value": "{color.stone.300}", "$type": "color" },
  "text-on-accent":   { "$value": "{color.white}",     "$type": "color" },
  "text-on-critical": { "$value": "{color.white}",     "$type": "color" },
  "text-on-success":  { "$value": "{color.white}",     "$type": "color" },
  "text-on-warning":  { "$value": "{color.stone.900}", "$type": "color" },
  "text-on-info":     { "$value": "{color.white}",     "$type": "color" },

  "border":           { "$value": "{color.stone.200}", "$type": "color" },
  "border-emphasis":  { "$value": "{color.stone.900}", "$type": "color" },
  "border-recede":    { "$value": "{color.stone.100}", "$type": "color" },

  "accent":           { "$value": "{color.stone.900}", "$type": "color", "$description": "Primary brand/action colour. Project overrides typically replace this." },
  "accent-recede":    { "$value": "{color.stone.100}", "$type": "color" },
  "critical":         { "$value": "{color.red}",       "$type": "color" },
  "success":          { "$value": "{color.emerald}",   "$type": "color" },
  "warning":          { "$value": "{color.amber}",     "$type": "color" },
  "info":             { "$value": "{color.sky}",       "$type": "color" },

  "font-sans":    { "$value": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif", "$type": "fontFamily" },
  "font-serif":   { "$value": "ui-serif, Georgia, 'Times New Roman', serif", "$type": "fontFamily" },
  "font-mono":    { "$value": "ui-monospace, SFMono-Regular, Menlo, Consolas, monospace", "$type": "fontFamily" },
  "font-display": { "$value": "ui-serif, Georgia, 'Times New Roman', serif", "$type": "fontFamily" },

  "type-size-xs":      { "$value": "0.75rem",  "$type": "dimension" },
  "type-size-sm":      { "$value": "0.875rem", "$type": "dimension" },
  "type-size-base":    { "$value": "1rem",     "$type": "dimension" },
  "type-size-lg":      { "$value": "1.125rem", "$type": "dimension" },
  "type-size-xl":      { "$value": "1.25rem",  "$type": "dimension" },
  "type-size-2xl":     { "$value": "1.5rem",   "$type": "dimension" },
  "type-size-3xl":     { "$value": "1.875rem", "$type": "dimension" },
  "type-size-display": { "$value": "4.5rem",   "$type": "dimension" },

  "leading-tight":  { "$value": "1.15", "$type": "number" },
  "leading-normal": { "$value": "1.4",  "$type": "number" },
  "leading-prose":  { "$value": "1.6",  "$type": "number" },
  "leading-loose":  { "$value": "1.9",  "$type": "number" },

  "tracking-tight":  { "$value": "-0.02em", "$type": "dimension" },
  "tracking-normal": { "$value": "0em",     "$type": "dimension" },
  "tracking-wide":   { "$value": "0.05em",  "$type": "dimension" },

  "measure-prose": { "$value": "65ch", "$type": "dimension" },

  "space-0":  { "$value": "0",       "$type": "dimension" },
  "space-1":  { "$value": "0.25rem", "$type": "dimension" },
  "space-2":  { "$value": "0.5rem",  "$type": "dimension" },
  "space-3":  { "$value": "0.75rem", "$type": "dimension" },
  "space-4":  { "$value": "1rem",    "$type": "dimension" },
  "space-6":  { "$value": "1.5rem",  "$type": "dimension" },
  "space-8":  { "$value": "2rem",    "$type": "dimension" },
  "space-12": { "$value": "3rem",    "$type": "dimension" },
  "space-16": { "$value": "4rem",    "$type": "dimension" },
  "space-24": { "$value": "6rem",    "$type": "dimension" },
  "space-32": { "$value": "8rem",    "$type": "dimension" },

  "space-stack-compact": { "$value": "0.5rem", "$type": "dimension" },
  "space-stack-normal":  { "$value": "1rem",   "$type": "dimension" },
  "space-stack-loose":   { "$value": "2rem",   "$type": "dimension" },
  "space-inline-tight":  { "$value": "0.25rem","$type": "dimension" },
  "space-inline-normal": { "$value": "0.5rem", "$type": "dimension" },
  "space-card":          { "$value": "1.5rem", "$type": "dimension" },
  "space-panel":         { "$value": "1.5rem", "$type": "dimension" },
  "space-frame":         { "$value": "1rem",   "$type": "dimension" },

  "radius-none":  { "$value": "0",         "$type": "dimension" },
  "radius-sm":    { "$value": "0.125rem",  "$type": "dimension" },
  "radius-md":    { "$value": "0.375rem",  "$type": "dimension" },
  "radius-lg":    { "$value": "0.5rem",    "$type": "dimension" },
  "radius-pill":  { "$value": "9999px",    "$type": "dimension" },
  "radius-card":  { "$value": "0.5rem",    "$type": "dimension" },
  "radius-frame": { "$value": "0.25rem",   "$type": "dimension" },
  "radius-media": { "$value": "0.25rem",   "$type": "dimension" },

  "motion-fast":     { "$value": "120ms", "$type": "duration" },
  "motion-normal":   { "$value": "200ms", "$type": "duration" },
  "motion-slow":     { "$value": "320ms", "$type": "duration" },
  "ease-standard":   { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "cubicBezier" },
  "ease-decelerate": { "$value": "cubic-bezier(0, 0, 0.2, 1)",   "$type": "cubicBezier" },
  "ease-accelerate": { "$value": "cubic-bezier(0.4, 0, 1, 1)",   "$type": "cubicBezier" }
}
