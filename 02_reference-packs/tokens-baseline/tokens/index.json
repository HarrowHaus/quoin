{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Quoin baseline token pack. Reference implementation of the v1.0 canonical namespace (164 tokens across 11 DTCG types). Stone-greyscale palette in OKLCH, system font stack, restrained spacing/type/motion scale.",

  "color": {
    "stone": {
      "50":  { "$value": "oklch(98% 0 0)",     "$type": "color" },
      "100": { "$value": "oklch(96% 0 0)",     "$type": "color" },
      "200": { "$value": "oklch(90% 0 0)",     "$type": "color" },
      "300": { "$value": "oklch(80% 0 0)",     "$type": "color" },
      "400": { "$value": "oklch(65% 0 0)",     "$type": "color" },
      "500": { "$value": "oklch(50% 0 0)",     "$type": "color" },
      "600": { "$value": "oklch(40% 0 0)",     "$type": "color" },
      "700": { "$value": "oklch(30% 0 0)",     "$type": "color" },
      "800": { "$value": "oklch(20% 0 0)",     "$type": "color" },
      "900": { "$value": "oklch(15% 0 0)",     "$type": "color" }
    },
    "white":        { "$value": "#ffffff",             "$type": "color" },
    "black":        { "$value": "#000000",             "$type": "color" },
    "red":          { "$value": "oklch(55% 0.22 25)",  "$type": "color" },
    "red-soft":     { "$value": "oklch(95% 0.04 25)",  "$type": "color" },
    "amber":        { "$value": "oklch(75% 0.18 80)",  "$type": "color" },
    "amber-soft":   { "$value": "oklch(96% 0.05 80)",  "$type": "color" },
    "emerald":      { "$value": "oklch(58% 0.18 155)", "$type": "color" },
    "emerald-soft": { "$value": "oklch(95% 0.05 155)", "$type": "color" },
    "sky":          { "$value": "oklch(70% 0.15 235)", "$type": "color" },
    "sky-soft":     { "$value": "oklch(95% 0.04 235)", "$type": "color" },
    "highlight":    { "$value": "oklch(88% 0.16 90)",  "$type": "color" },
    "scrim":        { "$value": "oklch(0% 0 0 / 0.5)", "$type": "color" }
  },

  "_comment_3_1_surfaces": "§3.1 color — surfaces (5)",
  "surface":          { "$value": "{color.stone.50}",  "$type": "color" },
  "surface-elevated": { "$value": "{color.white}",     "$type": "color" },
  "surface-recessed": { "$value": "{color.stone.100}", "$type": "color" },
  "surface-inverse":  { "$value": "{color.stone.900}", "$type": "color" },
  "scrim":            { "$value": "{color.scrim}",     "$type": "color" },

  "_comment_3_2_text": "§3.2 color — text (10)",
  "text":             { "$value": "{color.stone.700}", "$type": "color" },
  "text-emphasis":    { "$value": "{color.stone.900}", "$type": "color" },
  "text-recede":      { "$value": "{color.stone.500}", "$type": "color" },
  "text-disabled":    { "$value": "{color.stone.300}", "$type": "color" },
  "text-on-accent":   { "$value": "{color.white}",     "$type": "color" },
  "text-on-critical": { "$value": "{color.white}",     "$type": "color" },
  "text-on-success":  { "$value": "{color.white}",     "$type": "color" },
  "text-on-warning":  { "$value": "{color.stone.900}", "$type": "color" },
  "text-on-info":     { "$value": "{color.white}",     "$type": "color" },
  "highlight":        { "$value": "{color.highlight}", "$type": "color" },

  "_comment_3_3_borders": "§3.3 color — borders (3)",
  "border":           { "$value": "{color.stone.200}", "$type": "color" },
  "border-emphasis":  { "$value": "{color.stone.900}", "$type": "color" },
  "border-recede":    { "$value": "{color.stone.100}", "$type": "color" },

  "_comment_3_4_accent_status": "§3.4 color — accent and status (6)",
  "accent":           { "$value": "{color.stone.900}", "$type": "color" },
  "accent-recede":    { "$value": "{color.stone.100}", "$type": "color" },
  "critical":         { "$value": "{color.red}",       "$type": "color" },
  "success":          { "$value": "{color.emerald}",   "$type": "color" },
  "warning":          { "$value": "{color.amber}",     "$type": "color" },
  "info":             { "$value": "{color.sky}",       "$type": "color" },

  "_comment_3_5_focus_link_shadow": "§3.5 color — focus, links, shadow tint (5)",
  "focus-ring":   { "$value": "{color.stone.900}", "$type": "color" },
  "link":         { "$value": "{color.stone.700}", "$type": "color" },
  "link-visited": { "$value": "{color.stone.500}", "$type": "color" },
  "link-hover":   { "$value": "{color.stone.900}", "$type": "color" },
  "shadow-tint":  { "$value": "oklch(0% 0 0 / 0.1)", "$type": "color" },

  "_comment_3_6_spacing": "§3.6 dimension — spacing scale (14)",
  "space-0":  { "$value": "0",        "$type": "dimension" },
  "space-1":  { "$value": "0.25rem",  "$type": "dimension" },
  "space-2":  { "$value": "0.5rem",   "$type": "dimension" },
  "space-3":  { "$value": "0.75rem",  "$type": "dimension" },
  "space-4":  { "$value": "1rem",     "$type": "dimension" },
  "space-5":  { "$value": "1.25rem",  "$type": "dimension" },
  "space-6":  { "$value": "1.5rem",   "$type": "dimension" },
  "space-8":  { "$value": "2rem",     "$type": "dimension" },
  "space-10": { "$value": "2.5rem",   "$type": "dimension" },
  "space-12": { "$value": "3rem",     "$type": "dimension" },
  "space-16": { "$value": "4rem",     "$type": "dimension" },
  "space-20": { "$value": "5rem",     "$type": "dimension" },
  "space-24": { "$value": "6rem",     "$type": "dimension" },
  "space-32": { "$value": "8rem",     "$type": "dimension" },

  "_comment_3_7_semantic_spacing": "§3.7 dimension — semantic spacing (9)",
  "space-stack-compact": { "$value": "0.5rem",  "$type": "dimension" },
  "space-stack-normal":  { "$value": "1rem",    "$type": "dimension" },
  "space-stack-loose":   { "$value": "2rem",    "$type": "dimension" },
  "space-inline-tight":  { "$value": "0.25rem", "$type": "dimension" },
  "space-inline-normal": { "$value": "0.5rem",  "$type": "dimension" },
  "space-inline-loose":  { "$value": "1rem",    "$type": "dimension" },
  "space-card":          { "$value": "1.5rem",  "$type": "dimension" },
  "space-panel":         { "$value": "1.5rem",  "$type": "dimension" },
  "space-frame":         { "$value": "1rem",    "$type": "dimension" },

  "_comment_3_8_type_sizes": "§3.8 dimension — type sizes (10)",
  "type-size-xs":      { "$value": "0.75rem",  "$type": "dimension" },
  "type-size-sm":      { "$value": "0.875rem", "$type": "dimension" },
  "type-size-md":      { "$value": "1rem",     "$type": "dimension" },
  "type-size-lg":      { "$value": "1.125rem", "$type": "dimension" },
  "type-size-xl":      { "$value": "1.25rem",  "$type": "dimension" },
  "type-size-2xl":     { "$value": "1.5rem",   "$type": "dimension" },
  "type-size-3xl":     { "$value": "1.875rem", "$type": "dimension" },
  "type-size-4xl":     { "$value": "2.25rem",  "$type": "dimension" },
  "type-size-5xl":     { "$value": "3rem",     "$type": "dimension" },
  "type-size-display": { "$value": "4.5rem",   "$type": "dimension" },

  "_comment_3_9_tracking": "§3.9 dimension — tracking (3)",
  "tracking-tight":  { "$value": "-0.02em", "$type": "dimension" },
  "tracking-normal": { "$value": "0em",     "$type": "dimension" },
  "tracking-wide":   { "$value": "0.05em",  "$type": "dimension" },

  "_comment_3_10_radius": "§3.10 dimension — radius (9)",
  "radius-none":  { "$value": "0",         "$type": "dimension" },
  "radius-sm":    { "$value": "0.125rem",  "$type": "dimension" },
  "radius-md":    { "$value": "0.375rem",  "$type": "dimension" },
  "radius-lg":    { "$value": "0.5rem",    "$type": "dimension" },
  "radius-xl":    { "$value": "1rem",      "$type": "dimension" },
  "radius-pill":  { "$value": "9999px",    "$type": "dimension" },
  "radius-card":  { "$value": "0.5rem",    "$type": "dimension" },
  "radius-frame": { "$value": "0.25rem",   "$type": "dimension" },
  "radius-media": { "$value": "0.25rem",   "$type": "dimension" },

  "_comment_3_11_border_widths": "§3.11 dimension — border widths (4)",
  "border-width-hairline": { "$value": "0.5px", "$type": "dimension" },
  "border-width-sm":       { "$value": "1px",   "$type": "dimension" },
  "border-width-md":       { "$value": "2px",   "$type": "dimension" },
  "border-width-lg":       { "$value": "4px",   "$type": "dimension" },

  "_comment_3_12_focus_ring": "§3.12 dimension — focus ring metrics (2)",
  "focus-ring-width":  { "$value": "2px", "$type": "dimension" },
  "focus-ring-offset": { "$value": "2px", "$type": "dimension" },

  "_comment_3_13_icon_sizes": "§3.13 dimension — icon sizes (5)",
  "icon-size-xs": { "$value": "0.75rem", "$type": "dimension" },
  "icon-size-sm": { "$value": "1rem",    "$type": "dimension" },
  "icon-size-md": { "$value": "1.25rem", "$type": "dimension" },
  "icon-size-lg": { "$value": "1.5rem",  "$type": "dimension" },
  "icon-size-xl": { "$value": "2rem",    "$type": "dimension" },

  "_comment_3_14_containers": "§3.14 dimension — containers (4)",
  "container-narrow":  { "$value": "40rem", "$type": "dimension" },
  "container-default": { "$value": "64rem", "$type": "dimension" },
  "container-wide":    { "$value": "80rem", "$type": "dimension" },
  "container-full":    { "$value": "100%",  "$type": "dimension" },

  "_comment_3_15_measure_blur": "§3.15 dimension — measure + blur (4)",
  "measure-prose": { "$value": "65ch",  "$type": "dimension" },
  "blur-sm":       { "$value": "4px",   "$type": "dimension" },
  "blur-md":       { "$value": "12px",  "$type": "dimension" },
  "blur-lg":       { "$value": "24px",  "$type": "dimension" },

  "_comment_3_16_opacity": "§3.16 number — opacity (5)",
  "opacity-disabled":     { "$value": "0.38", "$type": "number" },
  "opacity-recede":       { "$value": "0.6",  "$type": "number" },
  "opacity-hover-layer":  { "$value": "0.08", "$type": "number" },
  "opacity-active-layer": { "$value": "0.12", "$type": "number" },
  "opacity-scrim":        { "$value": "0.5",  "$type": "number" },

  "_comment_3_17_z_index": "§3.17 number — z-index (8)",
  "z-base":     { "$value": "0",    "$type": "number" },
  "z-raised":   { "$value": "1",    "$type": "number" },
  "z-sticky":   { "$value": "100",  "$type": "number" },
  "z-dropdown": { "$value": "1000", "$type": "number" },
  "z-modal":    { "$value": "2000", "$type": "number" },
  "z-popover":  { "$value": "3000", "$type": "number" },
  "z-tooltip":  { "$value": "4000", "$type": "number" },
  "z-toast":    { "$value": "5000", "$type": "number" },

  "_comment_3_18_aspect": "§3.18 number — aspect ratios (4)",
  "aspect-square":   { "$value": "1.0",    "$type": "number" },
  "aspect-video":    { "$value": "1.7778", "$type": "number" },
  "aspect-portrait": { "$value": "0.75",   "$type": "number" },
  "aspect-banner":   { "$value": "3.0",    "$type": "number" },

  "_comment_3_19_leading": "§3.19 number — leading multipliers (4)",
  "leading-tight":  { "$value": "1.15", "$type": "number" },
  "leading-normal": { "$value": "1.4",  "$type": "number" },
  "leading-prose":  { "$value": "1.6",  "$type": "number" },
  "leading-loose":  { "$value": "1.9",  "$type": "number" },

  "_comment_3_20_fontFamily": "§3.20 fontFamily (9 — handoff additive)",
  "font-sans":    { "$value": "'Ranade Variable', 'Ranade', ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif", "$type": "fontFamily" },
  "font-serif":   { "$value": "'Junicode 2', 'Junicode', ui-serif, Georgia, 'Times New Roman', serif", "$type": "fontFamily" },
  "font-mono":    { "$value": "'Monaspace Neon Var', 'Monaspace Neon', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace", "$type": "fontFamily" },
  "font-display": { "$value": "'Junicode 2', 'Junicode', ui-serif, Georgia, 'Times New Roman', serif", "$type": "fontFamily" },
  "font-mono-warm":       { "$value": "'Monaspace Argon Var', 'Monaspace Argon', ui-monospace, SFMono-Regular, Menlo, monospace", "$type": "fontFamily" },
  "font-mono-slab":       { "$value": "'Monaspace Xenon Var', 'Monaspace Xenon', ui-monospace, SFMono-Regular, Menlo, monospace", "$type": "fontFamily" },
  "font-mono-script":     { "$value": "'Monaspace Radon Var', 'Monaspace Radon', ui-monospace, SFMono-Regular, Menlo, monospace", "$type": "fontFamily" },
  "font-mono-mechanical": { "$value": "'Monaspace Krypton Var', 'Monaspace Krypton', ui-monospace, SFMono-Regular, Menlo, monospace", "$type": "fontFamily" },
  "font-mono-pixel":      { "$value": "'Departure Mono', 'IBM Plex Mono', ui-monospace, SFMono-Regular, monospace", "$type": "fontFamily" },

  "_comment_3_21_fontWeight": "§3.21 fontWeight (6)",
  "font-weight-light":    { "$value": "300", "$type": "fontWeight" },
  "font-weight-regular":  { "$value": "400", "$type": "fontWeight" },
  "font-weight-medium":   { "$value": "500", "$type": "fontWeight" },
  "font-weight-semibold": { "$value": "600", "$type": "fontWeight" },
  "font-weight-bold":     { "$value": "700", "$type": "fontWeight" },
  "font-weight-black":    { "$value": "900", "$type": "fontWeight" },

  "_comment_3_22_motion": "§3.22 duration — motion (5)",
  "motion-instant": { "$value": "50ms",  "$type": "duration" },
  "motion-fast":    { "$value": "100ms", "$type": "duration" },
  "motion-normal":  { "$value": "200ms", "$type": "duration" },
  "motion-slow":    { "$value": "400ms", "$type": "duration" },
  "motion-slower":  { "$value": "800ms", "$type": "duration" },

  "_comment_3_23_easing": "§3.23 cubicBezier — easing (6)",
  "ease-linear":     { "$value": "cubic-bezier(0, 0, 1, 1)",     "$type": "cubicBezier" },
  "ease-standard":   { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "cubicBezier" },
  "ease-decelerate": { "$value": "cubic-bezier(0, 0, 0.2, 1)",   "$type": "cubicBezier" },
  "ease-accelerate": { "$value": "cubic-bezier(0.4, 0, 1, 1)",   "$type": "cubicBezier" },
  "ease-emphasized": { "$value": "cubic-bezier(0.2, 0, 0, 1)",   "$type": "cubicBezier" },
  "ease-spring":     { "$value": "cubic-bezier(0.5, 1.5, 0.5, 1)", "$type": "cubicBezier" },

  "_comment_3_24_shadow": "§3.24 shadow (composite, 7)",
  "shadow-xs": {
    "$type": "shadow",
    "$value": { "color": "{shadow-tint}", "offsetX": "0", "offsetY": "1px", "blur": "2px", "spread": "0", "inset": false }
  },
  "shadow-sm": {
    "$type": "shadow",
    "$value": { "color": "{shadow-tint}", "offsetX": "0", "offsetY": "1px", "blur": "3px", "spread": "0", "inset": false }
  },
  "shadow-md": {
    "$type": "shadow",
    "$value": [
      { "color": "{shadow-tint}", "offsetX": "0", "offsetY": "4px", "blur": "6px", "spread": "-1px", "inset": false },
      { "color": "{shadow-tint}", "offsetX": "0", "offsetY": "2px", "blur": "4px", "spread": "-1px", "inset": false }
    ]
  },
  "shadow-lg": {
    "$type": "shadow",
    "$value": [
      { "color": "{shadow-tint}", "offsetX": "0", "offsetY": "10px", "blur": "15px", "spread": "-3px", "inset": false },
      { "color": "{shadow-tint}", "offsetX": "0", "offsetY": "4px",  "blur": "6px",  "spread": "-2px", "inset": false }
    ]
  },
  "shadow-xl": {
    "$type": "shadow",
    "$value": [
      { "color": "{shadow-tint}", "offsetX": "0", "offsetY": "20px", "blur": "25px", "spread": "-5px", "inset": false },
      { "color": "{shadow-tint}", "offsetX": "0", "offsetY": "8px",  "blur": "10px", "spread": "-6px", "inset": false }
    ]
  },
  "shadow-2xl": {
    "$type": "shadow",
    "$value": { "color": "{shadow-tint}", "offsetX": "0", "offsetY": "25px", "blur": "50px", "spread": "-12px", "inset": false }
  },
  "shadow-inner": {
    "$type": "shadow",
    "$value": { "color": "{shadow-tint}", "offsetX": "0", "offsetY": "2px", "blur": "4px", "spread": "0", "inset": true }
  },
  "shadow-none": {
    "$type": "shadow",
    "$value": { "color": "transparent", "offsetX": "0", "offsetY": "0", "blur": "0", "spread": "0", "inset": false }
  },
  "shadow-focus": {
    "$type": "shadow",
    "$value": { "color": "{focus-ring}", "offsetX": "0", "offsetY": "0", "blur": "0", "spread": "{focus-ring-width}", "inset": false }
  },
  "shadow-focus-error": {
    "$type": "shadow",
    "$value": { "color": "{critical}", "offsetX": "0", "offsetY": "0", "blur": "0", "spread": "{focus-ring-width}", "inset": false }
  },

  "_comment_3_25_border_composite": "§3.25 border (composite, 3)",
  "border-default": {
    "$type": "border",
    "$value": { "color": "{border}", "width": "{border-width-sm}", "style": "solid" }
  },
  "border-emphasis-stroke": {
    "$type": "border",
    "$value": { "color": "{border-emphasis}", "width": "{border-width-md}", "style": "solid" }
  },
  "border-divider": {
    "$type": "border",
    "$value": { "color": "{border-recede}", "width": "{border-width-sm}", "style": "solid" }
  },

  "_comment_3_26_typography": "§3.26 typography (composite, 13)",
  "text-display": {
    "$type": "typography",
    "$value": {
      "fontFamily": "{font-display}",
      "fontSize": "{type-size-display}",
      "fontWeight": "{font-weight-bold}",
      "lineHeight": "{leading-tight}",
