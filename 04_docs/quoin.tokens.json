{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Quoin docs site — project-local token override. Layers on top of @quoin/tokens-geist (set in vite.config.ts) and gives the site its own identity rather than rendering as raw Geist. Same mechanism the Harrow Haus dogfood used: pack-defined defaults at the bottom, project brand at the top.",

  "surface":          { "$value": "oklch(98% 0.004 80)",   "$type": "color" },
  "surface-elevated": { "$value": "#ffffff",                "$type": "color" },
  "surface-recessed": { "$value": "oklch(95% 0.006 80)",   "$type": "color" },
  "surface-inverse":  { "$value": "oklch(14% 0.006 30)",   "$type": "color" },

  "text":             { "$value": "oklch(22% 0.010 30)",   "$type": "color" },
  "text-emphasis":    { "$value": "oklch(12% 0.012 30)",   "$type": "color" },
  "text-recede":      { "$value": "oklch(48% 0.010 30)",   "$type": "color" },

  "border":           { "$value": "oklch(86% 0.010 30)",   "$type": "color" },
  "border-emphasis":  { "$value": "oklch(14% 0.012 30)",   "$type": "color" },
  "border-recede":    { "$value": "oklch(92% 0.008 30)",   "$type": "color" },

  "accent":           { "$value": "oklch(14% 0.012 30)",   "$type": "color" },
  "accent-recede":    { "$value": "oklch(94% 0.014 30)",   "$type": "color" },

  "font-sans":    { "$value": "'Inter', -apple-system, BlinkMacSystemFont, system-ui, sans-serif", "$type": "fontFamily" },
  "font-serif":   { "$value": "'Newsreader', 'Crimson Pro', Georgia, ui-serif, serif",             "$type": "fontFamily" },
  "font-display": { "$value": "'Newsreader', 'Crimson Pro', Georgia, ui-serif, serif",             "$type": "fontFamily" },
  "font-mono":    { "$value": "'JetBrains Mono', 'Geist Mono', ui-monospace, monospace",           "$type": "fontFamily" },

  "type-size-display": { "$value": "5.5rem",   "$type": "dimension" },
  "type-size-3xl":     { "$value": "2.25rem",  "$type": "dimension" },
  "type-size-2xl":     { "$value": "1.75rem",  "$type": "dimension" },
  "type-size-xl":      { "$value": "1.375rem", "$type": "dimension" },

  "tracking-tight": { "$value": "-0.03em", "$type": "dimension" },
  "leading-tight":  { "$value": "1.05",    "$type": "number" },
  "leading-prose":  { "$value": "1.65",    "$type": "number" },
  "measure-prose":  { "$value": "62ch",    "$type": "dimension" },

  "radius-card":  { "$value": "0", "$type": "dimension" },
  "radius-frame": { "$value": "0", "$type": "dimension" },
  "radius-md":    { "$value": "0", "$type": "dimension" },
  "radius-lg":    { "$value": "0", "$type": "dimension" }
}
