{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "article-meta",
  "type": "registry:component",
  "title": "Article Meta",
  "description": "Article meta strip. Author (with optional avatar) + published date + reading-time, with conditional category, tag-list, and share-actions. Three density variants × three position variants. Reading time computed at build time, not runtime. Composes prim-label for tag-list.",
  "files": [
    {
      "path": "patterns/article-meta/quoin.pack.json",
      "type": "registry:file",
      "target": "quoin/article-meta/manifest.json"
    },
    {
      "path": "patterns/article-meta/primitives/index.json",
      "type": "registry:file",
      "target": "quoin/article-meta/primitives.json"
    },
    {
      "path": "patterns/article-meta/examples/index.html",
      "type": "registry:file",
      "target": "quoin/article-meta/examples/index.html"
    }
  ],
  "meta": {
    "quoinPackName": "@quoin/pattern-article-meta",
    "quoinPackVersion": "1.0.0",
    "usmlVersion": "^0.1.0",
    "packType": "pattern",
    "conformanceLevel": "Level 3",
    "optionalDependencies": [
      "label"
    ]
  }
}
