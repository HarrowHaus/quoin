    },
    {
      "path": "02_reference-packs/patterns/stat-card/examples/index.html",
      "type": "registry:file",
      "target": "quoin/stat-card/examples/index.html"
    }
  ],
  "meta": {
    "quoinPackName": "@quoin/pattern-stat-card",
    "quoinPackVersion": "1.0.0",
