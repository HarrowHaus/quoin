    },
    {
      "path": "patterns/prim-switcher/primitives/index.json",
      "type": "registry:file",
      "target": "quoin/prim-switcher/primitives.json"
    },
    {
      "path": "patterns/prim-switcher/examples/index.html",
      "type": "registry:file",
      "target": "quoin/prim-switcher/examples/index.html"
    }
  ],
  "meta": {
    "quoinPackName": "@quoin/prim-switcher",
    "quoinPackVersion": "1.0.0",
    "usmlVersion": "^0.1.0",
    "packType": "primitive",
    "conformanceLevel": "Level 3"
  }
