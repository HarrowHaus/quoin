{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "prose-aside",
  "type": "registry:component",
  "title": "Prose Aside",
  "description": "Prose aside (callout / admonition) for editorial and docs prose. Six semantic registers: note, tip, warning, danger, success, info. Token-driven colour + icon mapping per semantic; aria-label per role for screen readers.",
  "files": [
    {
      "path": "patterns/prose-aside/quoin.pack.json",
      "type": "registry:file",
      "target": "quoin/prose-aside/manifest.json"
    },
    {
      "path": "patterns/prose-aside/primitives/index.json",
      "type": "registry:file",
      "target": "quoin/prose-aside/primitives.json"
    },
    {
      "path": "patterns/prose-aside/examples/index.html",
      "type": "registry:file",
      "target": "quoin/prose-aside/examples/index.html"
    }
  ],
  "meta": {
    "quoinPackName": "@quoin/pattern-prose-aside",
    "quoinPackVersion": "1.0.0",
    "usmlVersion": "^0.1.0",
    "packType": "pattern",
    "conformanceLevel": "Level 3"
  }
}
