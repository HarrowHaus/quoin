{
  "$schema": "https://harrow.haus/quoin/schema/pack.json",
  "name": "@quoin/prim-switcher",
  "version": "1.0.0",
  "type": "primitive",
  "quoinVersion": "^0.1.0",
  "description": "Layout primitive — switch from row to column when container width drops below a threshold. Used for two-column heroes that go single-column, side-by-side comparisons that stack, any responsive 'side by side or stacked' composition. Phase 22.6.",
  "category": "layout",
  "variant": "primitive",
  "variants": ["threshold-narrow", "threshold-standard", "threshold-wide"],
  "exports": { "primitives": "./primitives/index.json" },
  "states": ["default", "stacked", "side-by-side"],
  "microStates": ["default"],
  "metadata": {
    "author": "Quoin",
    "license": "MIT",
    "homepage": "https://harrow.haus/quoin/primitives/switcher",
    "tags": ["primitive", "layout", "switcher", "row-to-column", "container-query"]
  },
  "peerPacks": {
    "@quoin/tokens-baseline": "^0.1.0"
  }
}
