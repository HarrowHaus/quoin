  "variants": ["min-narrow", "min-standard", "min-wide", "min-custom"],
  "exports": { "primitives": "./primitives/index.json" },
  "states": ["default"],
  "microStates": ["default"],
  "metadata": {
    "author": "Quoin",
    "license": "MIT",
    "homepage": "https://harrow.haus/quoin/primitives/grid",
    "tags": ["primitive", "layout", "grid", "auto-fit", "responsive"]
  },
  "peerPacks": {
    "@quoin/tokens-baseline": "^0.1.0"
  }
}
