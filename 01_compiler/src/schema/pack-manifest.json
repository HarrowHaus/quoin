{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harrow.haus/quoin/schema/pack.json",
  "title": "Quoin Pack Manifest",
  "type": "object",
  "required": ["name", "version", "type", "quoinVersion", "description", "exports"],
  "properties": {
    "$schema": { "type": "string" },
    "name": {
      "type": "string",
      "pattern": "^@[a-z0-9][a-z0-9-]*/[a-z][a-z0-9-]{1,31}$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "type": {
      "enum": [
        "token",
        "vocabulary",
        "implementation",
        "aesthetic",
        "theme",
        "template",
        "pattern",
        "icon"
      ],
      "description": "Pack type discriminator. Canonical value is 'aesthetic' for visual-only token-rebinding packs; 'theme' is accepted as a deprecated alias for backward compatibility and emits a one-line deprecation warning at load time. Other values: 'token' (rebind canonical tokens), 'vocabulary' (define semantic primitives), 'implementation' (CSS emitter), 'template' (page scaffold), 'pattern' (pre-composed pattern primitives), 'icon' (icon set). Backend packs (D.51) will add 'backend' in Phase 14."
    },
    "quoinVersion": { "type": "string" },
    "description": { "type": "string", "minLength": 1, "maxLength": 200 },
    "exports": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "type": "string" }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "author": { "type": "string" },
        "license": { "type": "string" },
        "homepage": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "attribution": {
      "type": "object",
      "required": ["sourceSystem", "sourceLicense", "harvestedAt"],
      "properties": {
        "sourceSystem": { "type": "string" },
        "sourceOrganization": { "type": "string" },
        "sourceUrl": { "type": "string" },
        "sourceCommit": { "type": "string", "description": "Git SHA, tag, or branch of the upstream source at extraction time. Added in Phase 3.5." },
        "sourceLicense": { "type": "string" },
        "harvestedAt": { "type": "string" },
        "harvestNotes": { "type": "string" },
        "fidelityTier": { "type": "string", "enum": ["A", "B", "C"], "description": "Phase 3.5 fidelity classification: A = byte-faithful extraction; B = extracted with mapping notes; C = extraction failed, designed-interpretation values stand." }
      },
      "additionalProperties": false
    },
    "peerPacks": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "optionalPeerPacks": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "Peer packs the pattern may compose under certain variants/states but does not require for all renderings. v3.G.17 enforcement reads peerPacks only; optionalPeerPacks is informational. Introduced Phase 22 Cons. 5 + formalized v3.G.21 (2026-05-20)."
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "status": {
      "type": "string",
      "enum": ["pending-3.5c-fill"],
      "description": "Phase 0.5 transitional status. Packs marked 'pending-3.5c-fill' emit validation warnings instead of errors for missing canonical tokens. Removed after Phase 3.5c populates the expanded namespace."
    },
    "category": {
      "type": "string",
      "description": "Template or pattern category (e.g. 'marketing', 'dashboard', 'button')."
    },
    "pages": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Template pack: list of page identifiers shipped (e.g. ['index', 'about', 'pricing'])."
    },
    "dependencies": {
      "type": "object",
      "description": "Template pack: peer packs the template depends on.",
      "properties": {
        "tokenPack": { "type": "string" },
        "implementationPack": { "type": "string" },
        "vocabularyPacks": { "type": "array", "items": { "type": "string" } },
        "themePack": { "type": "string" },
        "patternPacks": { "type": "array", "items": { "type": "string" } },
        "iconPacks": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "variant": {
      "type": "string",
      "description": "Pattern pack: variant identifier within a category (e.g. 'pill', 'block', 'compact')."
    },
    "states": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Pattern pack: pattern-level states the pack provides. MUST include 'default'."
    },
    "microStates": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Pattern pack: per-element micro-states. MUST include 'default' and 'focus'."
    },
    "iconStyle": {
      "type": "string",
      "enum": ["outline", "solid", "duotone", "bold", "bold-duotone", "two-tone"],
      "description": "Icon pack: visual style of the icon set."
    },
    "iconCount": {
      "type": "number",
      "minimum": 1,
      "description": "Icon pack: total number of icons in the set."
    },
    "recommendedSize": {
      "type": "object",
      "description": "Icon pack: recommended display sizes.",
      "required": ["min", "max", "sweetSpot"],
      "properties": {
        "min": { "type": "string" },
        "max": { "type": "string" },
        "sweetSpot": { "type": "string" }
      },
      "additionalProperties": false
    },
    "semanticTag": {
      "type": "string",
      "description": "Icon pack: the semantic tag the pack registers; defaults to 'icon'."
    },
    "sizeTokensConsumed": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Icon pack: canonical icon-size dimension tokens the pack reads."
    }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "token" } }, "required": ["type"] },
      "then": {
        "properties": {
          "exports": {
            "required": ["tokens"],
            "properties": { "tokens": { "type": "string" } }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "vocabulary" } }, "required": ["type"] },
      "then": {
        "properties": {
          "exports": {
            "required": ["primitives"],
            "properties": {
              "primitives": { "type": "string" },
              "componentTokens": { "type": "string" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "implementation" } }, "required": ["type"] },
      "then": {
        "properties": {
          "exports": {
            "required": ["emit", "metadata"],
            "properties": {
              "emit": { "type": "string" },
              "metadata": { "type": "string" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "aesthetic" } }, "required": ["type"] },
      "then": {
        "properties": {
          "exports": {
            "required": ["lightModeOverrides"],
            "properties": {
              "lightModeOverrides": { "type": "string" },
              "darkModeOverrides": { "type": "string" },
              "p3WideGamutOverrides": { "type": "string" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "theme" } }, "required": ["type"] },
      "then": {
        "properties": {
          "exports": {
            "required": ["lightModeOverrides"],
            "properties": {
              "lightModeOverrides": { "type": "string" },
              "darkModeOverrides": { "type": "string" },
              "p3WideGamutOverrides": { "type": "string" }
            }
          }
        },
        "$comment": "Deprecated alias for 'aesthetic'. Accepted for backward compatibility; loader emits a one-line deprecation warning at load time (D.52 rename, operator-locked 2026-05-18)."
      }
    },
    {
      "if": { "properties": { "type": { "const": "template" } }, "required": ["type"] },
      "then": {
        "required": ["category", "pages", "dependencies"],
        "properties": {
          "exports": {
            "required": ["pages"],
            "properties": {
              "pages": { "type": "string" }
            }
          },
          "dependencies": {
            "required": ["tokenPack", "implementationPack", "vocabularyPacks"]
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "pattern" } }, "required": ["type"] },
      "then": {
        "required": ["category", "states", "microStates"],
        "properties": {
          "exports": {
            "required": ["primitives"],
            "properties": {
              "primitives": { "type": "string" },
              "componentTokens": { "type": "string" }
            }
          },
          "states": {
            "type": "array",
            "contains": { "const": "default" }
          },
          "microStates": {
            "type": "array",
            "allOf": [
              { "contains": { "const": "default" } },
              { "contains": { "const": "focus" } }
            ]
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "icon" } }, "required": ["type"] },
      "then": {
        "required": ["iconStyle", "iconCount", "recommendedSize"],
        "properties": {
          "exports": {
            "required": ["icons", "manifest"],
            "properties": {
              "icons": { "type": "string" },
              "manifest": { "type": "string" }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
